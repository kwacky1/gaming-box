# Required
GH_TOKEN=           # GitHub token with gist scope
GIST_ID=            # ID of the pinned gist to update

# Steam (optional — omit if not using Steam)
STEAM_API_KEY=      # From https://steamcommunity.com/dev/apikey
STEAM_ID=           # Your 64-bit Steam ID

# Xbox (optional — omit if not using Xbox)
OPENXBL_API_KEY=    # From https://xbl.io
